# Groq LLM configuration
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.3

# Hugging Face dataset
HF_DATASET_NAME=ManikaSaini/zomato-restaurant-recommendation

# Local cache path for preprocessed restaurant data
DATA_CACHE_PATH=data/restaurants.parquet

# Recommendation pipeline tuning
MAX_CANDIDATES_FOR_LLM=20
TOP_K_RECOMMENDATIONS=5

# Budget tier thresholds (INR, cost for two)
BUDGET_LOW_MAX=500
BUDGET_MEDIUM_MAX=1500

# CORS origins for frontend (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
